{
  "name": "mon-launcher",
  "version": "1.2.23",
  "description": "Launcher Solisyum",
  "main": "main.js",
  "author": "Mathéo",
  "scripts": {
    "start": "electron .",
    "build": "taskkill /F /IM electron.exe /T 2>nul & taskkill /F /IM \"Mon Launcher.exe\" 2>nul & rimraf dist && electron-builder --win --publish always",
    "release": "npm version patch && npm run build && git push && git push --tags"
  },
  "build": {
    "appId": "com.monlauncher.app",
    "productName": "Mon Launcher",
    "directories": {
      "output": "build_output"
    },
    "artifactName": "SolisyumLauncher-Setup-${version}.${ext}",
    "compression": "maximum",
    "asarUnpack": [
      "*.jar"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Math170",
        "repo": "mon-modpack-serveur"
      }
    ]
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.1.8",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^5.0.5"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "rimraf": "^6.1.3"
  }
}
